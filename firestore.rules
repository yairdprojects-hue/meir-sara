rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /pniot/{docId} {
      allow create: if request.resource.data.keys().hasOnly([
        'שם',
        'אימייל', 
        'נושא',
        'הודעה',
        'timestamp'
      ])
      && request.resource.data['שם'] is string
      && request.resource.data['שם'].size() > 0
      && request.resource.data['שם'].size() <= 200
      && request.resource.data['אימייל'] is string
      && request.resource.data['אימייל'].size() >= 3 
      && request.resource.data['אימייל'].size() <= 320
      && request.resource.data['נושא'] is string
      && request.resource.data['נושא'].size() > 0
      && request.resource.data['נושא'].size() <= 300
      && request.resource.data['הודעה'] is string
      && request.resource.data['הודעה'].size() > 0
      && request.resource.data['הודעה'].size() <= 10000
      && request.resource.data['timestamp'] is string
      && request.resource.data['timestamp'].size() > 0
      && request.resource.data['timestamp'].size() <= 64;

      allow read, update, delete: if false;
    }
  }
}